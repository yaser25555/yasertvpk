    <style name="PlayerControlButton">
    <item name="android:layout_width">@dimen/player_control_size</item>
    <item name="android:layout_height">@dimen/player_control_size</item>
    <item name="android:background">@drawable/player_btn_focus</item>
    <item name="android:focusable">true</item>
    <item name="android:focusableInTouchMode">true</item>
  </style>
    <style name="PlayerControlButtonLarge" parent="PlayerControlButton">
    <item name="android:layout_width">@dimen/player_control_large</item>
    <item name="android:layout_height">@dimen/player_control_large</item>
  </style>
    <style name="TabStyle">
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">match_parent</item>
    <item name="android:layout_weight">1</item>
    <item name="android:gravity">center</item>
    <item name="android:textColor">@color/tab_text_selector</item>
    <item name="android:textSize">@dimen/tab_text_size</item>
    <item name="android:maxLines">1</item>
    <item name="android:ellipsize">end</item>
    <item name="android:paddingHorizontal">6dp</item>
    <item name="android:layout_marginHorizontal">3dp</item>
    <item name="android:focusable">true</item>
    <item name="android:clickable">true</item>
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:textStyle">bold</item>
    <item name="android:letterSpacing">0.04</item>
  </style>
    <style name="Theme.YasserTV" parent="Theme.AppCompat.NoActionBar">
    <item name="colorPrimary">@color/accent</item>
    <item name="colorPrimaryDark">@color/bg</item>
    <item name="colorAccent">@color/accent</item>
    <item name="android:colorBackground">@color/bg</item>
    <item name="android:windowBackground">@color/bg</item>
