<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/bg"
  android:orientation="horizontal">

  <!-- Left: Player & Splash Section (40%) -->
  <RelativeLayout
    android:id="@+id/playerPanel"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="2"
    android:background="@android:color/black"
    android:clickable="true"
    android:focusable="false">

    <TextureView
      android:id="@+id/textureView"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:clickable="true"
      android:focusable="false" />

    <!-- Channel Info Badges (shown when playing) -->
    <LinearLayout
      android:id="@+id/playerBadges"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentTop="true"
      android:layout_alignParentEnd="true"
      android:layout_margin="6dp"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:visibility="gone">

      <TextView
        android:id="@+id/badgeQuality"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:background="#CC1a73e8"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:textColor="#FFF"
        android:textSize="10sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/badgePlayer"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:layout_marginStart="4dp"
        android:background="#CCF0A500"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:textColor="#000"
        android:textSize="10sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/tvChannelName"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_alignParentStart="true"
      android:layout_alignParentTop="true"
      android:layout_marginStart="8dp"
      android:layout_marginTop="8dp"
      android:layout_marginEnd="72dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:shadowColor="#000"
      android:shadowDx="1"
      android:shadowDy="1"
      android:shadowRadius="3"
      android:textColor="#FFF"
      android:textSize="@dimen/channel_name_size"
      android:visibility="gone" />

    <TextView
      android:id="@+id/tvStatus"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:textColor="#ffcc00"
      android:textSize="13sp"
      android:visibility="gone" />

    <LinearLayout
      android:id="@+id/playerControls"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_alignParentBottom="true"
      android:background="#CC000000"
      android:orientation="vertical"
      android:padding="@dimen/player_controls_padding">

      <LinearLayout
        android:id="@+id/seekRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <SeekBar
          android:id="@+id/seekBar"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:max="1000" />

        <TextView
          android:id="@+id/tvTime"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="6dp"
          android:minWidth="40dp"
          android:textColor="#fff"
          android:textSize="11sp" />
      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
          android:id="@+id/btnPrev"
          style="@style/PlayerControlButton"
          android:contentDescription="السابق"
          android:src="@android:drawable/ic_media_previous" />

        <ImageButton
          android:id="@+id/btnPlayPause"
          style="@style/PlayerControlButtonLarge"
          android:contentDescription="تشغيل/إيقاف"
          android:src="@android:drawable/ic_media_pause" />

        <ImageButton
          android:id="@+id/btnNext"
          style="@style/PlayerControlButton"
          android:contentDescription="التالي"
          android:src="@android:drawable/ic_media_next" />

        <View
          android:layout_width="0dp"
          android:layout_height="0dp"
          android:layout_weight="1" />

        <ImageButton
          android:id="@+id/btnFullscreen"
          style="@style/PlayerControlButton"
          android:contentDescription="شاشة كاملة"
          android:src="@drawable/ic_fullscreen" />

        <TextView
          android:id="@+id/btnSwitchPlayer"
          android:layout_width="wrap_content"
          android:layout_height="36dp"
          android:background="@drawable/btn_m3u_import"
          android:clickable="true"
          android:focusable="true"
          android:gravity="center"
          android:paddingHorizontal="8dp"
          android:text="IJK"
          android:textColor="#FFF"
          android:textSize="10sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/btnSettings"
          android:layout_width="34dp"
          android:layout_height="34dp"
          android:background="@drawable/btn_m3u_import"
          android:clickable="true"
          android:focusable="true"
          android:gravity="center"
          android:text="⚙"
          android:textColor="#FFF"
          android:textSize="16sp" />
      </LinearLayout>
    </LinearLayout>
  </RelativeLayout>

  <View
    android:layout_width="1dp"
    android:layout_height="match_parent"
    android:background="@color/divider" />

  <!-- Right: Content Section (60%) -->
  <LinearLayout
    android:id="@+id/contentPanel"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="3"
    android:background="@drawable/content_overlay_bg"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingTop="50dp"
    android:paddingBottom="6dp"
    android:visibility="visible">

    <TextView
      android:id="@+id/tvSectionTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:textColor="@color/text"
      android:textSize="@dimen/tv_section_title_size"
      android:paddingVertical="4dp"
      android:visibility="gone" />

    <HorizontalScrollView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:fillViewport="true"
      android:scrollbars="none">

      <LinearLayout
        android:id="@+id/tabs"
        android:layout_width="match_parent"
        android:layout_height="@dimen/tab_height"
        android:background="@drawable/tab_bar_bg"
        android:gravity="center_vertical"
        android:minWidth="280dp"
        android:orientation="horizontal"
        android:padding="2dp">

        <TextView
          android:id="@+id/tabLive"
          style="@style/TabStyle"
          android:text="@string/live" />

        <TextView
          android:id="@+id/tabMovies"
          style="@style/TabStyle"
          android:text="@string/movies" />

        <TextView
          android:id="@+id/tabSeries"
          style="@style/TabStyle"
          android:text="@string/series" />

        <TextView
          android:id="@+id/tabFavorites"
          style="@style/TabStyle"
          android:text="@string/favorites" />

        <TextView
          android:id="@+id/tabM3u"
          style="@style/TabStyle"
          android:text="@string/m3u_tab" />
      </LinearLayout>
    </HorizontalScrollView>

    <Spinner
      android:id="@+id/categorySpinner"
      android:layout_width="match_parent"
      android:layout_height="@dimen/category_height"
      android:layout_marginTop="4dp"
      android:background="@drawable/search_bg"
      android:dropDownWidth="match_parent"
      android:gravity="center_vertical"
      android:paddingHorizontal="10dp"
      android:textSize="@dimen/category_text_size" />

    <HorizontalScrollView
      android:id="@+id/categoryScroll"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:scrollbars="none"
      android:visibility="gone">

      <LinearLayout
        android:id="@+id/categoryRow"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/category_height"
        android:gravity="center_vertical"
        android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="28dp"
      android:layout_marginTop="4dp"
      android:orientation="horizontal">

      <EditText
        android:id="@+id/searchInput"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/search_bg"
        android:hint="@string/search_hint"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingHorizontal="8dp"
        android:textColor="@color/text"
        android:textColorHint="@color/text_hint"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/btnImportM3uTop"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:background="@drawable/btn_m3u_import"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:text="M3U"
        android:textColor="#FFF"
        android:textSize="11sp"
        android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
      android:id="@+id/progressBar"
      android:layout_width="24dp"
      android:layout_height="24dp"
      android:layout_gravity="center"
      android:layout_marginTop="8dp" />

    <TextView
      android:id="@+id/errorText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:gravity="center"
      android:textColor="@color/muted"
      android:textSize="12sp"
      android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/grid"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_marginTop="4dp"
      android:layout_weight="1"
      android:clipToPadding="false"
      android:paddingBottom="4dp"
      android:scrollbars="vertical" />
  </LinearLayout>
</LinearLayout>
