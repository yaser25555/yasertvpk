<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_focused="true">
    <shape android:shape="rectangle">
      <solid android:color="#CCF0A500" />
      <stroke android:width="3dp" android:color="@color/accent" />
      <corners android:radius="@dimen/tv_card_radius" />
    </shape>
  </item>
  <item android:state_selected="true">
    <shape android:shape="rectangle">
      <solid android:color="#88FFFFFF" />
      <stroke android:width="2dp" android:color="@color/border_accent" />
      <corners android:radius="@dimen/tv_card_radius" />
    </shape>
  </item>
  <item>
    <shape android:shape="rectangle">
      <solid android:color="#882A1E44" />
      <corners android:radius="@dimen/tv_card_radius" />
    </shape>
  </item>
</selector>
